  "keyFeatures": [
    "Type-safe web development with Haskell",
    "HSX templating (JSX-like syntax for HTML)",
    "Built-in IDE with visual schema designer",
    "Live reloading development server",
    "Auto-refresh for real-time view updates",
    "Integrated PostgreSQL with type-safe queries",
    "Built-in authentication and authorization",
    "Background job queue and processing",
    "File storage with multiple backends",
    "WebSocket and real-time features",
    "Nix-based reproducible development environment"
  ],
  "publicApiSurface": [
    "IHP.Prelude - Core Haskell utilities and re-exports",
    "IHP.ControllerPrelude - Controller helpers and imports",
    "IHP.ViewPrelude - View rendering and HSX",
    "IHP.RouterSupport - Type-safe routing",
    "IHP.QueryBuilder - Type-safe SQL query builder",
    "IHP.ModelSupport - Database model operations",
    "IHP.AuthSupport.Authentication - User authentication",
    "IHP.AuthSupport.Authorization - Access control",
    "IHP.ValidationSupport - Form validation",
    "IHP.FileStorage - File upload and storage",
    "IHP.Job.Queue - Background job processing",
    "IHP.Mail - Email composition and sending",
    "IHP.AutoRefresh - Real-time view updates",
    "IHP.WebSocket - WebSocket support",
    "IHP.DataSync - Real-time data synchronization",
    "IHP.GraphQL - GraphQL API support",
    "ihp-new - CLI tool to create new projects",
    "devenv up - Start development server"
  ]
